APP_HOST=0.0.0.0 # Dirección IP en la que la aplicación escuchará (0.0.0.0 para escuchar en todas las interfaces)
APP_PORT=8000 # Puerto en el que la aplicación escuchará
APP_VERSION=0.1.0 # Versión de la API. Se establece en la definición de OpenAPI.

DEV_MODE=False # Se ejecuta en modo desarrollo, con recarga automática y más verbosidad en los logs
CLEAR_DB_ON_STARTUP=False # Si se establece en True, la base de datos se limpiará cada vez que se inicie la aplicación (útil para desarrollo)

DB_TYPE=sqlite # Tipo de base de datos a usar (sqlite, postgresql, mysql, etc.) # Actualmente solo se soporta sqlite, pero se puede extender en el futuro para soportar otros tipos de bases de datos
SQLITE_DB_PATH=./data/projects.db # Ruta del archivo de la base de datos SQLite (si se usa SQLite)

LOG_LEVEL=INFO # Nivel de log (DEBUG, INFO, WARNING, ERROR, CRITICAL)

# Orígenes permitidos. Se pueden especificar múltiples orígenes separados por comas. Por ejemplo: http://localhost:3000,https://tu-frontend.com
# En producción debería ser https://alejoide.com o el dominio donde esté alojado el frontend.
CORS_ALLOW_ORIGINS=http://localhost:4321

# URL base pública desde la que se sirven las imágenes guardadas localmente.
# Debe coincidir con el host/puerto donde corre la API. En producción usar el dominio real.
IMAGES_BASE_URL=http://localhost:8000/images